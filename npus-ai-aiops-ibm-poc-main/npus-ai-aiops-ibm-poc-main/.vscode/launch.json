{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Jupyter Notebook",
      "type": "debugpy",
      "request": "launch",
      "module": "jupyter",
      "args": ["notebook", "--no-browser"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Attach to Kernel",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false
    }
  ]
}
