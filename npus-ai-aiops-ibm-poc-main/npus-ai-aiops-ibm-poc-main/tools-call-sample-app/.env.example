# ==============================================================================
# Azure + Databricks values
# ==============================================================================
DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
DATABRICKS_AUTH_TYPE="azure-client-secret"
WAREHOUSE_ID="your_sql_warehouse_id"
DATABRICKS_CATALOG="samples"
DATABRICKS_SCHEMA="bakehouse"
ARM_CLIENT_ID="your_azure_client_id"
ARM_CLIENT_SECRET="your_azure_client_secret"
ARM_TENANT_ID="your_azure_tenant_id"

# ==============================================================================
# LLM Provider: "nestle" (default) or "openai"
# ==============================================================================
LLM_PROVIDER=nestle #LLM_PROVIDER=openai

# ==============================================================================
# OpenAI API (used when LLM_PROVIDER=openai)
# ==============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # Optional: for Azure OpenAI or proxy

# ==============================================================================
# NESGEN API Configuration
# ==============================================================================
# Required credentials
NESTLE_CLIENT_ID="your_client_id"
NESTLE_CLIENT_SECRET="your_client_secret"

# Optional: Override default NESGEN endpoints and models
# NESGEN_URL=https://your-nesgen-endpoint/completions?api-version=2024-10-21
# NESGEN_API_BASE=https://eur-sdr-int-pub.nestle.com/api/dv-exp-sandbox-openai-api/1
# NESGEN_MODEL=gpt-4o-mini
# NESGEN_API_VERSION=2024-10-21
# Optional: NESGEN request configuration
# NESGEN_MAX_RETRIES=3
# NESGEN_TIMEOUT=180

# Optional: NESGEN Embeddings configuration
# NESGEN_EMBEDDING_API_BASE=https://eur-sdr-int-pub.nestle.com/api/dv-exp-sandbox-openai-api/1
# NESGEN_EMBEDDING_MODEL=text-embedding-3-small
# NESGEN_EMBEDDING_API_VERSION=2024-10-21

# ==============================================================================
# Common LLM Settings
# ==============================================================================
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024

# ==============================================================================
# Langfuse Observability
# ==============================================================================
LANGFUSE_SECRET_KEY="your_secret_key"
LANGFUSE_PUBLIC_KEY="your_public_key"
LANGFUSE_HOST="https://cloud.langfuse.com"

# For self-hosted / local Langfuse only:
# LANGFUSE_SSL_CERT=/path/to/corporate-ca-bundle.pem  # Trust a custom CA bundle
# LANGFUSE_SSL_VERIFY=false                           # Disable TLS cert check (corporate proxy)
# LANGFUSE_SDK_INTEGRATION_TRACING_ENABLED=false     # Disable SDK's internal OTEL meta-tracing.
#   Local Langfuse doesn't expose /api/public/otel/v1/traces, so leaving this
#   enabled causes "Internal server error" errors in the logs after tool calls.

# ==============================================================================
# MCP Server
# ==============================================================================
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8052
